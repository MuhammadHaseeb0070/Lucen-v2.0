# ═══════════════════════════════════════════════════════════════════════════
#  Lucen — Supabase Edge Functions Environment Configuration
#  These must be set in your Supabase Dashboard → Edge Functions → Secrets
#  or locally using `supabase secrets set`.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Supabase Required (Auto-injected by Supabase) ────────────────────────
# You DO NOT need to set these manually in the dashboard, but you might
# need them if testing locally.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── App URL (Required) ───────────────────────────────────────────────────
# Needed for CORS and Checkout Redirects
VITE_APP_URL=https://your-domain.com

# ─── OpenRouter (Required) ────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_ONLINE_MODEL=openai/gpt-4o-mini # Optional fallback for web search
ABSOLUTE_OUTPUT_CEILING=32768 # Optional, defaults to 32768

# ─── Web Search / Intent Classification ───────────────────────────────────
WEB_INTENT_MODEL=openai/gpt-4o-mini # Optional, defaults to gpt-4o-mini
WEB_INTENT_INPUT_COST_PER_1M=0.15 # Optional, defaults to 0
WEB_INTENT_OUTPUT_COST_PER_1M=0.60 # Optional, defaults to 0
TAVILY_API_KEY=tvly-your-key # Required if web search is enabled
WEBSEARCH_DEBUG=false # Optional, logs debug info when true

# ─── Image Vision / Describe Image ────────────────────────────────────────
VISION_HELPER_MODEL=openai/gpt-4o-mini # Required for `describe-image`
VISION_HELPER_INPUT_COST_PER_1M=0.15 # Optional, defaults to 0
VISION_HELPER_OUTPUT_COST_PER_1M=0.60 # Optional, defaults to 0

# ─── Embeddings / RAG ─────────────────────────────────────────────────────
EMBEDDING_MODEL=google/gemini-embedding-001 # Optional, defaults to gemini
EMBEDDING_INPUT_COST_PER_1M=0 # Optional, defaults to 0

# ─── Lemon Squeezy (Required if using billing) ────────────────────────────
LEMON_SQUEEZY_API_KEY=your-ls-api-key
LEMON_SQUEEZY_STORE_ID=your-store-id
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMON_SQUEEZY_TEST_MODE=true # Optional, set to "false" in production
LS_VARIANT_REGULAR=12345 # Must match VITE_LS_VARIANT_REGULAR
LS_VARIANT_PRO=67890 # Must match VITE_LS_VARIANT_PRO
CREDITS_REGULAR=4000 # Optional, defaults to 4000
CREDITS_PRO=10000 # Optional, defaults to 10000
