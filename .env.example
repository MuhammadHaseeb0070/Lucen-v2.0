# Supabase (from your project dashboard -> Settings -> API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# App
VITE_APP_NAME=Lucen

# Comma-separated list of admin emails (shown the Owner Dashboard)
VITE_ADMIN_EMAILS=you@example.com

# Models (OpenRouter model IDs -- see https://openrouter.ai/models)
# Fallback used when main/side chat models are not set
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini
# Override per chat type (optional -- falls back to VITE_OPENROUTER_MODEL)
VITE_MAIN_CHAT_MODEL=openai/gpt-4o-mini
VITE_SIDE_CHAT_MODEL=openai/gpt-4o-mini
# Set to "true" if your model supports reasoning tokens (e.g. o1, deepseek-r1)
VITE_SUPPORTS_REASONING=false

# Payment Provider Toggle: "gumroad" or "lemonsqueezy" (default)
VITE_PAYMENT_PROVIDER=gumroad

# Lemon Squeezy (frontend — used when VITE_PAYMENT_PROVIDER=lemonsqueezy)
VITE_LS_VARIANT_REGULAR=12345
VITE_LS_VARIANT_PRO=67890
#
# Lemon Squeezy (server — set in Supabase Edge Function secrets, not here)
# LEMON_SQUEEZY_STORE_ID = numeric store id (Lemon dashboard → Settings)

# Gumroad (frontend — used when VITE_PAYMENT_PROVIDER=gumroad)
VITE_GUMROAD_PRODUCT_URL=https://haseebmuhammad23.gumroad.com/l/xnpzvs
#
# Gumroad (server — set in Supabase Edge Function secrets, not here)
# GUMROAD_ACCESS_TOKEN = API access token (Gumroad Settings → Advanced)
# GUMROAD_WEBHOOK_SECRET = for HMAC verification (optional)
# GUMROAD_TIER_REGULAR_ID = tier/option ID for Regular
# GUMROAD_TIER_PRO_ID = tier/option ID for Pro
# Token Capacity (used to compute dynamic output budgets per request)
# Set these to match your model's actual specs — avoids truncated responses.
# Grok defaults shown below. Adjust for other models.
#   Context window = total tokens the model can see (input + output combined)
#   Max output     = maximum tokens the model can generate in one response
VITE_MODEL_CONTEXT_WINDOW=131072
VITE_MODEL_MAX_OUTPUT=32768
