# ═══════════════════════════════════════════════════════════════════════════
#  Lucen — environment configuration
#  Copy this file to `.env` and fill in the values for your deployment.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────────────────
# From your project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── App ──────────────────────────────────────────────────────────────────
VITE_APP_NAME=Lucen

# Comma-separated list of admin emails (shown the Owner Dashboard)
VITE_ADMIN_EMAILS=you@example.com


# ═══════════════════════════════════════════════════════════════════════════
#  MODEL CONFIGURATION
#
#  You define each model's real specs here so the app can size its output
#  budget, prune context, and log real USD cost dynamically.
#
#  Look up every value for your chosen model at https://openrouter.ai/models
#  and the model's own docs (for TOKENS_PER_SECOND / REASONING_LEAK).
# ═══════════════════════════════════════════════════════════════════════════

# ─── Fallback model (used when role-specific vars are blank) ──────────────
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini


# ╔═════════════════════════════════════════════════════════════════════════╗
# ║  MAIN chat model — the primary model users talk to.                     ║
# ╚═════════════════════════════════════════════════════════════════════════╝

# OpenRouter model slug. Find it in https://openrouter.ai/models.
#   openai/gpt-4o                 openai/gpt-4o-mini
#   anthropic/claude-sonnet-4.5   anthropic/claude-opus-4
#   minimaxai/minimax-m2          minimaxai/minimax-m2.5
#   google/gemini-2.5-pro         google/gemini-2.5-flash
#   deepseek/deepseek-r1          x-ai/grok-4
VITE_MAIN_CHAT_MODEL=minimaxai/minimax-m2

# Friendly display name shown in the UI (optional; defaults to last slash part)
VITE_MAIN_CHAT_MODEL_NAME=MiniMax M2

# Total input + output tokens the model supports in one conversation.
# From the model's OpenRouter page. Examples:
#   GPT-4o          = 128000      Claude 4.5 Sonnet = 200000
#   MiniMax M2      = 200000      Gemini 2.5 Pro    = 1000000
#   DeepSeek R1     = 163840      Grok 4            = 262144
VITE_MAIN_CHAT_CONTEXT_WINDOW=200000

# Max completion tokens the model can produce in a single API call.
# This is the model's capability, NOT our per-call cap. We'll never ask
# for more than this number in one call. Examples:
#   GPT-4o            = 16384     Claude 4.5 Sonnet = 64000
#   MiniMax M2        = 128000    Gemini 2.5 Pro    = 65536
#   DeepSeek R1       = 163840
VITE_MAIN_CHAT_MAX_OUTPUT=128000

# Set "true" for models with a reasoning / thinking channel.
# Enables routing of `delta.reasoning` into the reasoning UI section.
#   true:  DeepSeek R1, o1, MiniMax M2, Grok reasoning, Claude extended thinking
#   false: GPT-4o / GPT-4o-mini, Claude Sonnet/Opus (non-thinking), Gemini Flash
VITE_MAIN_CHAT_SUPPORTS_REASONING=true

# Set "true" ONLY for models whose reasoning LEAKS INTO the `content`
# channel instead of being cleanly separated into `reasoning_content`.
# When true, the per-call output budget is doubled for artifact mode to
# absorb the thinking tokens that eat into the final answer.
#   true:  MiniMax M2, some DeepSeek R1 provider routes (vLLM-backed)
#   false: GPT-4o, Claude, Gemini, official DeepSeek-R1 via OpenRouter
VITE_MAIN_CHAT_REASONING_LEAK=true

# Set "true" if the model natively accepts image inputs in its messages.
# When false (default), images are routed through the vision helper
# (describe-image edge function) and the main model receives a text
# description instead of raw pixels.
#   true:  GPT-4o, Claude 3.5/4 Sonnet, Gemini 2.5 Pro, Grok 4 Vision
#   false: MiniMax M2, DeepSeek R1 (text-only)
VITE_MAIN_MODEL_SUPPORTS_VISION=false

# Observed output throughput in tokens per second. Used with
# VITE_PLATFORM_MAX_STREAM_SECONDS to compute a safe per-call cap so a
# single streamed response finishes before Supabase's 150s idle timeout.
# Measure with a stopwatch on a long generation, or use these defaults:
#   GPT-4o-mini       ≈ 100      GPT-4o            ≈ 80
#   Claude 4.5 Sonnet ≈ 60       Gemini 2.5 Pro    ≈ 100
#   MiniMax M2        ≈ 40       DeepSeek R1       ≈ 25 (slow, reasoning-heavy)
VITE_MAIN_CHAT_TOKENS_PER_SECOND=40

# USD cost per 1,000,000 tokens. Copy exactly from the model's OpenRouter
# page. Used to log real dollar cost in usage_logs.usd_cost.
#   Example (MiniMax M2 as of 2026): $0.30 input, $1.20 output per 1M
VITE_MAIN_CHAT_INPUT_COST_PER_1M=0.30
VITE_MAIN_CHAT_OUTPUT_COST_PER_1M=1.20


# ╔═════════════════════════════════════════════════════════════════════════╗
# ║  SIDE chat model — lightweight model used for title generation,         ║
# ║  side-chat refinements, and sometimes classify-intent.                  ║
# ║  Pick a cheap fast model here (e.g. gpt-4o-mini or gemini-flash).       ║
# ╚═════════════════════════════════════════════════════════════════════════╝

VITE_SIDE_CHAT_MODEL=openai/gpt-4o-mini
VITE_SIDE_CHAT_MODEL_NAME=GPT-4o mini
VITE_SIDE_CHAT_CONTEXT_WINDOW=128000
VITE_SIDE_CHAT_MAX_OUTPUT=16384
VITE_SIDE_CHAT_SUPPORTS_REASONING=false
VITE_SIDE_CHAT_REASONING_LEAK=false
VITE_SIDE_MODEL_SUPPORTS_VISION=false
VITE_SIDE_CHAT_TOKENS_PER_SECOND=100
VITE_SIDE_CHAT_INPUT_COST_PER_1M=0.15
VITE_SIDE_CHAT_OUTPUT_COST_PER_1M=0.60


# ═══════════════════════════════════════════════════════════════════════════
#  PLATFORM BUDGETS (rarely need changing — these are tuned for Supabase
#  Edge Functions on the default plan).
# ═══════════════════════════════════════════════════════════════════════════

# Max seconds a single SSE stream can safely run before Supabase's 150s
# idle timeout kicks in. Leave at 140 (10s safety margin). NEVER raise
# above 145 — you'll start getting 504s.
VITE_PLATFORM_MAX_STREAM_SECONDS=140

# Maximum number of continuation chunks per request.
# When the model gets cut off by the per-call cap, we automatically
# continue. These numbers cap the total retries so runaway generations
# can't rack up unbounded cost.
#   12 for artifact = up to 12 × perCallCap tokens of total output
#    4 for chat     = normal chat rarely needs more than a couple
VITE_CONTINUATION_MAX_CHUNKS_ARTIFACT=12
VITE_CONTINUATION_MAX_CHUNKS_CHAT=4

# Hard safety ceiling regardless of model — protects against runaway costs.
# Even if the model claims it can output 128k tokens in one call, we will
# never ask for more than this in a single API request.
VITE_ABSOLUTE_OUTPUT_CEILING=32768

# Watchdog: if the stream receives no data line for this many milliseconds
# we abort it and trigger a continuation retry. Covers provider stalls
# (OpenRouter routing to a slow backend) without hanging the UI forever.
VITE_STREAM_IDLE_TIMEOUT_MS=30000

# Mid-stream DB write throttle. Every N milliseconds during streaming we
# flush the current partial content to Supabase so a page refresh or
# socket drop never loses work. Lower = more resilient but more DB writes.
# Claude.ai uses ~1000; 1500 is a good balance.
VITE_MIDSTREAM_PERSIST_MS=1500


# ═══════════════════════════════════════════════════════════════════════════
#  LEMON SQUEEZY (billing)
# ═══════════════════════════════════════════════════════════════════════════

# Variant IDs (frontend)
# Get from Lemon Squeezy Dashboard → Products → Your Product → Variants
VITE_LS_VARIANT_REGULAR=12345
VITE_LS_VARIANT_PRO=67890

# Server secrets live in Supabase Edge Function secrets (NOT here):
#   LEMON_SQUEEZY_API_KEY          API key from Lemon Squeezy Settings → API
#   LEMON_SQUEEZY_STORE_ID         numeric store id (Lemon dashboard → Settings)
#   LEMON_SQUEEZY_WEBHOOK_SECRET   signing secret from your webhook config
#   LS_VARIANT_REGULAR             same variant ID as VITE_LS_VARIANT_REGULAR
#   LS_VARIANT_PRO                 same variant ID as VITE_LS_VARIANT_PRO
#   CREDITS_REGULAR                credits per Regular billing cycle (default: 4000)
#   CREDITS_PRO                    credits per Pro billing cycle (default: 10000)
#   LEMON_SQUEEZY_TEST_MODE        "true" for test checkouts


# ═══════════════════════════════════════════════════════════════════════════
#  SERVER-SIDE SECRETS (set in Supabase Dashboard → Edge Functions → Secrets,
#  NOT in this .env file).
# ═══════════════════════════════════════════════════════════════════════════
#
#   OPENROUTER_API_KEY         OpenRouter API key (server-only).
#   SUPABASE_URL               Auto-injected by Supabase (do not set manually).
#   SUPABASE_SERVICE_ROLE_KEY  Auto-injected by Supabase (do not set manually).
#
#   VISION_HELPER_MODEL        Model used by the `describe-image` function to
#                              silently describe user-uploaded images with
#                              conversation context (must support image input).
#                              Examples:
#                                google/gemini-2.0-flash-001
#                                openai/gpt-4o-mini
#                                anthropic/claude-3.5-sonnet
#
#   WEB_INTENT_MODEL           Lightweight classifier used by `classify-intent`
#                              to decide whether to run a web search. Small &
#                              cheap models work well.
#                              Default: openai/gpt-4o-mini
#
#   EMBEDDING_MODEL            Embedding model used by `embed` and
#                              `retrieve-chunks` for file RAG. Both functions
#                              MUST use the same model (same vector space).
#                              Default: google/gemini-embedding-001
#
#   OPENROUTER_ONLINE_MODEL    Model used when a web search turn falls back to
#                              OpenRouter's native online plugin (rarely hit —
#                              Tavily handles most searches via classify-intent).
#
#   TAVILY_API_KEY             Tavily web-search API key for live web results.
#
#   # Per-call output cap (server-side safety). These MUST match the client
#   # values in outputBudget.ts. Only change if you're running a custom fork.
#   PLATFORM_MAX_STREAM_SECONDS   = 140
#   ABSOLUTE_OUTPUT_CEILING       = 32768


# ═══════════════════════════════════════════════════════════════════════════
#  DEV-ONLY TRANSPARENCY
# ═══════════════════════════════════════════════════════════════════════════
#
# VITE_DEV_PAYLOAD_CAPTURE   When "true", the Usage tab shows an eye icon next
#                            to every row. Clicking it opens a modal with the
#                            EXACT request and response payloads of that API
#                            call (chat-proxy, classify-intent, describe-image,
#                            embed, retrieve-chunks). Payloads live in a
#                            browser-only ring buffer (last 200 calls) and are
#                            cleared on page reload — they NEVER leave the
#                            user's browser. Set to "false" (or leave unset)
#                            in production so end users can't see raw prompts.
#
# Example for local dev:
#   VITE_DEV_PAYLOAD_CAPTURE = true


# ═══════════════════════════════════════════════════════════════════════════
#  LEGACY VARS (still honored for backwards compatibility — prefer the
#  role-specific vars above for new deployments).
# ═══════════════════════════════════════════════════════════════════════════
#
# VITE_MODEL_CONTEXT_WINDOW    Fallback context window if role-specific not set
# VITE_MODEL_MAX_OUTPUT        Fallback max output if role-specific not set
# VITE_SUPPORTS_REASONING      Fallback reasoning flag
