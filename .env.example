# OpenRouter (optional — for local dev fallback; do NOT set in Vercel production)
VITE_OPENROUTER_API_KEY=your-openrouter-key
VITE_OPENROUTER_MODEL=deepseek/deepseek-v3.2
VITE_APP_NAME=Lucen

# Supabase — fill these in after creating your project at supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe Pro price ID (from Stripe Dashboard → Products → Price). Set in Vercel for production.
VITE_STRIPE_PRO_PRICE_ID=price_xxx
