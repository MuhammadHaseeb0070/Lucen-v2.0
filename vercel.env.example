# ═══════════════════════════════════════════════════════════════════════════
#  Lucen — Frontend Environment Configuration (Vercel/Vite)
#  Copy this file to `.env` in the root and fill in the values.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Supabase (Required) ──────────────────────────────────────────────────
# From your project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── App Info (Optional) ──────────────────────────────────────────────────
VITE_APP_NAME=Lucen
# Comma-separated list of admin emails (shown on the Owner Dashboard)
VITE_ADMIN_EMAILS=you@example.com
VITE_LOG_LEVEL=warn # Default is debug in DEV, warn in PROD

# ─── Developer / Debugging (Optional) ─────────────────────────────────────
# Captures payloads in the Usage tab for debugging API calls. (Don't use in prod)
VITE_DEV_PAYLOAD_CAPTURE=false

# ─── Lemon Squeezy Subscription (Required if using subscriptions) ─────────
VITE_LS_VARIANT_REGULAR=12345
VITE_LS_VARIANT_PRO=67890

# ═══════════════════════════════════════════════════════════════════════════
#  MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Note: Fallbacks are provided in the code, but you should specify these 
# in production. Look up specs at https://openrouter.ai/models.

# ─── MAIN chat model (Required) ───────────────────────────────────────────
VITE_MAIN_CHAT_MODEL=minimaxai/minimax-m2
VITE_MAIN_CHAT_MODEL_NAME=MiniMax M2
VITE_MAIN_CHAT_CONTEXT_WINDOW=200000
VITE_MAIN_CHAT_MAX_OUTPUT=128000
VITE_MAIN_CHAT_SUPPORTS_REASONING=true
VITE_MAIN_CHAT_REASONING_LEAK=true
VITE_MAIN_MODEL_SUPPORTS_VISION=false
VITE_MAIN_CHAT_TOKENS_PER_SECOND=40
VITE_MAIN_CHAT_INPUT_COST_PER_1M=0.30
VITE_MAIN_CHAT_OUTPUT_COST_PER_1M=1.20

# ─── SIDE chat model (Required) ───────────────────────────────────────────
# Used for title generation, side-chat refinements, intent classification
VITE_SIDE_CHAT_MODEL=openai/gpt-4o-mini
VITE_SIDE_CHAT_MODEL_NAME=GPT-4o mini
VITE_SIDE_CHAT_CONTEXT_WINDOW=128000
VITE_SIDE_CHAT_MAX_OUTPUT=16384
VITE_SIDE_CHAT_SUPPORTS_REASONING=false
VITE_SIDE_CHAT_REASONING_LEAK=false
VITE_SIDE_MODEL_SUPPORTS_VISION=false
VITE_SIDE_CHAT_TOKENS_PER_SECOND=100
VITE_SIDE_CHAT_INPUT_COST_PER_1M=0.15
VITE_SIDE_CHAT_OUTPUT_COST_PER_1M=0.60

# ─── CODING chat model (Executor) (Required) ──────────────────────────────
# Used for artifact patching and step-by-step execution plan implementation
VITE_CODING_MODEL=qwen/qwen-2.5-coder-32b-instruct
VITE_CODING_MODEL_NAME=Qwen 2.5 Coder 32B
VITE_CODING_CONTEXT_WINDOW=32768
VITE_CODING_MAX_OUTPUT=8192
VITE_CODING_SUPPORTS_REASONING=false
VITE_CODING_REASONING_LEAK=false
VITE_CODING_SUPPORTS_VISION=false
VITE_CODING_TOKENS_PER_SECOND=150
VITE_CODING_INPUT_COST_PER_1M=0.07
VITE_CODING_OUTPUT_COST_PER_1M=0.14

# ─── Fallback Model (Optional) ────────────────────────────────────────────
# Used if the main or side models aren't specified
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini
VITE_OPENROUTER_MODEL_NAME=GPT-4o mini

# ─── Platform Budgets (Optional, defaults provided in code) ───────────────
VITE_PLATFORM_MAX_STREAM_SECONDS=140
VITE_CONTINUATION_MAX_CHUNKS_ARTIFACT=2
VITE_CONTINUATION_MAX_CHUNKS_CHAT=2
VITE_ABSOLUTE_OUTPUT_CEILING=6000
VITE_CHAT_OUTPUT_CEILING=1400
VITE_ARTIFACT_OUTPUT_CEILING=4500
VITE_STREAM_IDLE_TIMEOUT_MS=30000
VITE_MIDSTREAM_PERSIST_MS=1500
